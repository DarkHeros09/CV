package homepage

templ About(bio string) {
	<section id="about" class="section-container py-12">
		<div class="section-heading">
			<span class="text-accent">{ ">" }</span>
			<h2 class="font-mono text-lg font-semibold text-foreground">about</h2>
			<div class="section-heading-line"></div>
		</div>
		<div class="relative pl-4 border-l-2 border-border">
			<p class="text-muted-foreground leading-relaxed max-w-2xl whitespace-pre-line">
				{ bio }
			</p>
		</div>
	</section>
}
